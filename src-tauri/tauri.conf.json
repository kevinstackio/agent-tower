{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HelloWord",
  "version": "0.1.0",
  "identifier": "com.agenttower.helloword",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "HelloWord",
        "width": 960,
        "height": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "shortDescription": "A minimal HelloWord desktop app.",
    "category": "Utility"
  }
}
